# ============================================================
# Home Bartender AI — docker-compose level variables
# ------------------------------------------------------------
# These are consumed by the ROOT docker-compose.yml. The app-level
# secrets/config (JWT_SECRET, IMAGE_API_KEY, TEXT_API_KEY, ...) live in
# the project-root ./.env (see ../.env.example) which compose loads into
# the backend via `env_file`. This file documents only the variables that
# shape the compose topology itself (ports, volumes, image tags, creds).
#
# Copy to the PROJECT ROOT as .env and merge with ../.env.example:
#   cat .env.example infra/.env.example > .env   # then edit values
#
# NEVER commit a filled-in .env. No real secrets in this file — placeholders only.
# ============================================================

# ---- Build / release ----
# Tag applied to the locally built backend/web images. Use a version or
# git SHA in CI so rollback = redeploy a previous tag (see infra/README.md).
IMAGE_TAG=local
NODE_ENV=production

# ---- Host port mappings (host:container) ----
BACKEND_PORT=3000          # backend API   -> http://localhost:3000/api/v1  (swagger /docs)
WEB_PORT=8080              # web (nginx)    -> http://localhost:8080
GATEWAY_PORT=80            # optional reverse proxy (profile: gateway)
POSTGRES_PORT=5432
MINIO_PORT=9000            # S3 API
MINIO_CONSOLE_PORT=9001    # MinIO web console -> http://localhost:9001

# ---- Postgres ----
POSTGRES_USER=bartender
POSTGRES_PASSWORD=change-me-locally     # placeholder — set a real value in .env
POSTGRES_DB=bartender

# ---- Object storage (MinIO) ----
# Compose injects these as MinIO root creds AND the backend's S3 creds.
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change-me-locally    # placeholder — set a real value in .env
STORAGE_BUCKET=bartender
# Public base URL the backend hands to clients for poster/media links.
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/bartender

# ---- Web build arg ----
# Baked into the Vue bundle at build time. For the gateway profile use a
# same-origin path like /api/v1 instead.
VITE_API_BASE_URL=http://localhost:3000/api/v1
