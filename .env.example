# ============================================================
# Home Bartender AI — 环境变量示例（复制为 .env，勿提交真实值）
# ============================================================

# ---- 通用 ----
NODE_ENV=development

# ---- 后端服务 ----
BACKEND_PORT=3000
# 数据库（开发默认 sqlite，生产用 postgres）
DATABASE_URL=postgres://bartender:bartender@localhost:5432/bartender

# ---- 鉴权 ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---- 文本大模型（配方/文案）Provider，可配置 ----
TEXT_PROVIDER=stub            # stub | openai-compatible
TEXT_API_BASE_URL=
TEXT_API_KEY=
TEXT_MODEL=

# ---- 图像大模型（海报）Provider ----
# 默认 gpt-image-2，OpenAI 兼容端点
IMAGE_PROVIDER=stub           # stub | gpt-image-2
IMAGE_API_BASE_URL=https://api.rcouyi.com/v1
IMAGE_MODEL=gpt-image-2
# 真实密钥仅在本地 .env 注入，切勿提交！（已暴露的 key 请及时轮换）
IMAGE_API_KEY=

# ---- 对象存储（图片/海报）----
STORAGE_DRIVER=local          # local | s3-compatible(MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=bartender
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/bartender

# ---- 前端 Web ----
VITE_API_BASE_URL=http://localhost:3000/api/v1
