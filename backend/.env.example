# ============================================================
# Home Bartender AI — Backend environment example
# Copy to backend/.env. NEVER commit real secrets / API keys.
# ============================================================

NODE_ENV=development
BACKEND_PORT=3000

# ---- Database ----
# Dev defaults to a local SQLite file when DATABASE_URL is unset.
# For postgres, set e.g. postgres://bartender:bartender@localhost:5432/bartender
# DATABASE_URL=postgres://bartender:bartender@localhost:5432/bartender
SQLITE_PATH=bartender-dev.sqlite

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Text LLM provider (recipes / copy) ----
TEXT_PROVIDER=stub            # stub | openai-compatible
TEXT_API_BASE_URL=
TEXT_API_KEY=
TEXT_MODEL=

# ---- Image model provider (posters) ----
# Defaults to the deterministic stub when IMAGE_API_KEY is empty.
IMAGE_PROVIDER=stub           # stub | gpt-image-2
IMAGE_API_BASE_URL=https://api.rcouyi.com/v1
IMAGE_MODEL=gpt-image-2
# Real key only injected locally — NEVER commit.
IMAGE_API_KEY=

# ---- Poster generation ----
POSTER_TIMEOUT_MS=30000

# ---- Object storage (public base URL for generated assets) ----
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/bartender
