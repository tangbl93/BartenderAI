# Base URL of the backend API (matches OpenAPI server url)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# When "true", the UI uses the in-browser mock adapter and works with NO backend.
# Set to "false" (or remove) to talk to a real backend.
VITE_USE_MOCK=true

# Dev-server proxy target for /api (used by `npm run dev`)
VITE_API_PROXY_TARGET=http://localhost:3000
